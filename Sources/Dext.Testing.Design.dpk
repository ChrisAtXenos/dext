package Dext.Testing.Design;

{$R *.res}
{$IFDEF IMPLICITBUILDING This IFDEF should not be used by users}
{$ALIGN 8}
{$ASSERTIONS ON}
{$BOOLEVAL OFF}
{$DEBUGINFO OFF}
{$EXTENDEDSYNTAX ON}
{$IMPORTEDDATA ON}
{$IOCHECKS ON}
{$LOCALSYMBOLS ON}
{$LONGSTRINGS ON}
{$OPENSTRINGS ON}
{$OPTIMIZATION OFF}
{$OVERFLOWCHECKS ON}
{$RANGECHECKS ON}
{$REFERENCEINFO ON}
{$SAFEDIVIDE OFF}
{$STACKFRAMES ON}
{$TYPEDADDRESS OFF}
{$VARSTRINGCHECKS ON}
{$WRITEABLECONST OFF}
{$MINENUMSIZE 1}
{$IMAGEBASE $400000}
{$DEFINE DEBUG}
{$ENDIF IMPLICITBUILDING}
{$DESCRIPTION 'Dext Framework - Native IDE Test Explorer & Runner'}
{$DESIGNONLY}
{$IMPLICITBUILD ON}

requires
  rtl,
  designide,
  vcl,
  Dext.Core,
  Dext.Net,
  Dext.Testing;

contains
  Dext.Testing.Design.Registration in 'Testing\Design\Dext.Testing.Design.Registration.pas',
  Dext.Testing.Design.Expert in 'Testing\Design\Dext.Testing.Design.Expert.pas',
  Dext.Testing.Design.DockableForm in 'Testing\Design\Dext.Testing.Design.DockableForm.pas',
  Dext.Testing.Design.Server in 'Testing\Design\Dext.Testing.Design.Server.pas',
  Dext.Testing.Design.AST in 'Testing\Design\Dext.Testing.Design.AST.pas',
  Dext.Testing.Design.Gutter in 'Testing\Design\Dext.Testing.Design.Gutter.pas';

end.
