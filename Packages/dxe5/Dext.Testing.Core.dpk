package Dext.Testing.Core;

{$R *.res}
{$IFDEF IMPLICITBUILDING This IFDEF should not be used by users}
{$ALIGN 8}
{$ASSERTIONS ON}
{$BOOLEVAL OFF}
{$DEBUGINFO OFF}
{$EXTENDEDSYNTAX ON}
{$IMPORTEDDATA ON}
{$IOCHECKS ON}
{$LOCALSYMBOLS OFF}
{$LONGSTRINGS ON}
{$OPENSTRINGS ON}
{$OPTIMIZATION ON}
{$OVERFLOWCHECKS OFF}
{$RANGECHECKS OFF}
{$REFERENCEINFO OFF}
{$SAFEDIVIDE OFF}
{$STACKFRAMES OFF}
{$TYPEDADDRESS OFF}
{$VARSTRINGCHECKS ON}
{$WRITEABLECONST OFF}
{$MINENUMSIZE 1}
{$IMAGEBASE $400000}
{$DEFINE RELEASE}
{$ENDIF IMPLICITBUILDING}
{$DESCRIPTION 'Dext Framework - Testing Utilities (Mocking, Interception, Assertions)'}
{$LIBSUFFIX '190'}
{$RUNONLY}
{$IMPLICITBUILD OFF}

requires
  rtl,
  IndySystem,
  IndyProtocols,
  IndyCore,
  Dext.Core,
  Dext.EF.Core,
  Dext.Web.Core;

contains
  Dext.Assertions in '..\..\Sources\Testing\Dext.Assertions.pas',
  Dext.Mocks.Auto in '..\..\Sources\Testing\Dext.Mocks.Auto.pas',
  Dext.Mocks.Interceptor in '..\..\Sources\Testing\Dext.Mocks.Interceptor.pas',
  Dext.Mocks.Matching in '..\..\Sources\Testing\Dext.Mocks.Matching.pas',
  Dext.Mocks in '..\..\Sources\Testing\Dext.Mocks.pas',
  Dext.Testing.Attributes in '..\..\Sources\Testing\Dext.Testing.Attributes.pas',
  Dext.Testing.Console in '..\..\Sources\Testing\Dext.Testing.Console.pas',
  Dext.Testing.DI in '..\..\Sources\Testing\Dext.Testing.DI.pas',
  Dext.Testing.Fluent in '..\..\Sources\Testing\Dext.Testing.Fluent.pas',
  Dext.Testing.History in '..\..\Sources\Testing\Dext.Testing.History.pas',
  Dext.Testing.Report in '..\..\Sources\Testing\Dext.Testing.Report.pas',
  Dext.Testing.Runner in '..\..\Sources\Testing\Dext.Testing.Runner.pas',
  Dext.Testing.Listeners.Telemetry in '..\..\Sources\Testing\Dext.Testing.Listeners.Telemetry.pas',
  Dext.Testing in '..\..\Sources\Testing\Dext.Testing.pas',
  Dext.Testing.Host in '..\..\Sources\Testing\Dext.Testing.Host.pas',
  Dext.Testing.Integration in '..\..\Sources\Common\Dext.Testing.Integration.pas';

end.

