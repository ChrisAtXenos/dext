package Dext.Testing.Design;

{$R *.res}
{$IFDEF IMPLICITBUILDING This IFDEF should not be used by users}
{$ALIGN 8}
{$ASSERTIONS ON}
{$BOOLEVAL OFF}
{$DEBUGINFO OFF}
{$EXTENDEDSYNTAX ON}
{$IMPORTEDDATA ON}
{$IOCHECKS ON}
{$LOCALSYMBOLS OFF}
{$LONGSTRINGS ON}
{$OPENSTRINGS ON}
{$OPTIMIZATION ON}
{$OVERFLOWCHECKS OFF}
{$RANGECHECKS OFF}
{$REFERENCEINFO OFF}
{$SAFEDIVIDE OFF}
{$STACKFRAMES OFF}
{$TYPEDADDRESS OFF}
{$VARSTRINGCHECKS ON}
{$WRITEABLECONST OFF}
{$MINENUMSIZE 1}
{$IMAGEBASE $400000}
{$DEFINE RELEASE}
{$ENDIF IMPLICITBUILDING}
{$DESCRIPTION 'Dext Framework - Native IDE Test Explorer & Runner'}
{$LIBSUFFIX '250'}
{$DESIGNONLY}
{$IMPLICITBUILD OFF}

requires
  rtl,
  designide,
  vcl,
  Dext.Core,
  Dext.Net.Core,
  Dext.Testing.Core;

contains
  Dext.Testing.Design.Registration in '..\..\Sources\Testing\Design\Dext.Testing.Design.Registration.pas',
  Dext.Testing.Design.Expert in '..\..\Sources\Testing\Design\Dext.Testing.Design.Expert.pas',
  Dext.Testing.Design.DockableForm in '..\..\Sources\Testing\Design\Dext.Testing.Design.DockableForm.pas',
  Dext.Testing.Design.Server in '..\..\Sources\Testing\Design\Dext.Testing.Design.Server.pas',
  Dext.Testing.Design.AST in '..\..\Sources\Testing\Design\Dext.Testing.Design.AST.pas',
  Dext.Testing.Design.Gutter in '..\..\Sources\Testing\Design\Dext.Testing.Design.Gutter.pas',
  Dext.Testing.Design.Coverage in '..\..\Sources\Testing\Design\Dext.Testing.Design.Coverage.pas',
  Dext.Testing.Design.Presenter in '..\..\Sources\Testing\Design\Dext.Testing.Design.Presenter.pas';

end.
